{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist-worker",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node"],
    "noEmit": false,
    "allowImportingTsExtensions": false
  },
  "include": [
    "workers/**/*.ts",
    "src/lib/email/**/*.ts",
    "src/lib/jobs/**/*.ts",
    "src/lib/queues/**/*.ts",
    "src/lib/logger.ts",
    "src/lib/redis.ts",
    "src/lib/env.ts",
    "src/lib/prisma/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "dist",
    "dist-worker",
    "src/app",
    "src/components",
    "src/features",
    "src/lib/api",
    "src/lib/query-client.ts"
  ]
}