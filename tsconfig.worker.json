{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist-worker",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "lib": ["ES2022"],
    "noEmit": false,
    "allowImportingTsExtensions": false
  },
  "include": [
    "workers/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "dist",
    "dist-worker",
    "src/app",
    "src/components"
  ]
}